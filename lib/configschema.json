{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "chartIdIncrementor": {
            "type": "number"
          },
          "charts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "method": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "bars": {
                          "anyOf": [
                            {
                              "const": "minmax"
                            },
                            {
                              "const": "stddev"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "type": {
                          "const": "aggregate_avg"
                        },
                        "x": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "y": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "xTimeBin": {
                          "enum": [
                            "day",
                            "hour",
                            "minute",
                            "month",
                            "second",
                            "week",
                            "weekday",
                            "year"
                          ]
                        }
                      },
                      "required": [
                        "bars",
                        "type",
                        "x",
                        "y"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "columns": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "fn": {
                          "type": "string"
                        },
                        "type": {
                          "const": "custom"
                        }
                      },
                      "required": [
                        "columns",
                        "fn",
                        "type"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "enum": [
                            "aggregate_count_unique",
                            "aggregate_sum",
                            "value"
                          ]
                        },
                        "x": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "y": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "xTimeBin": {
                          "enum": [
                            "day",
                            "hour",
                            "minute",
                            "month",
                            "second",
                            "week",
                            "weekday",
                            "year"
                          ]
                        }
                      },
                      "required": [
                        "type",
                        "x",
                        "y"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "const": "aggregate_count"
                        },
                        "x": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "xTimeBin": {
                          "enum": [
                            "day",
                            "hour",
                            "minute",
                            "month",
                            "second",
                            "week",
                            "weekday",
                            "year"
                          ]
                        }
                      },
                      "required": [
                        "type",
                        "x"
                      ],
                      "additionalProperties": false
                    }
                  ]
                },
                "pos": {
                  "type": "object",
                  "properties": {
                    "height": {
                      "type": "number"
                    },
                    "width": {
                      "type": "number"
                    },
                    "x": {
                      "type": "number"
                    },
                    "y": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "height",
                    "width",
                    "x",
                    "y"
                  ],
                  "additionalProperties": false
                },
                "style": {
                  "enum": [
                    "bar",
                    "line",
                    "pie"
                  ]
                },
                "subtitle": {
                  "type": "string"
                },
                "table": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "title": {
                  "type": "string"
                },
                "xTitle": {
                  "type": "string"
                },
                "yTitle": {
                  "type": "string"
                },
                "barColor": {
                  "type": "string"
                },
                "breakdown": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "cumulative": {
                  "const": true
                },
                "joins": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "baseColumn": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "foreignColumn": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "table": {
                        "type": "string"
                      },
                      "type": {
                        "enum": [
                          "inner",
                          "left",
                          "right"
                        ]
                      }
                    },
                    "required": [
                      "baseColumn",
                      "foreignColumn",
                      "table",
                      "type"
                    ],
                    "additionalProperties": false
                  }
                },
                "limit": {
                  "type": "number"
                },
                "sortCol": {
                  "type": "string"
                },
                "sortDesc": {
                  "const": true
                },
                "traceColors": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "where": {
                  "type": "string"
                },
                "xFormatter": {
                  "type": "string"
                },
                "yFormatter": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "method",
                "pos",
                "style",
                "subtitle",
                "table",
                "title",
                "xTitle",
                "yTitle"
              ],
              "additionalProperties": false
            }
          },
          "details": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "client": {
                    "enum": [
                      "cockroachdb",
                      "mariadb",
                      "mssql",
                      "mysql",
                      "oracledb",
                      "postgres",
                      "redshift"
                    ]
                  },
                  "database": {
                    "type": "string"
                  },
                  "host": {
                    "type": "string"
                  },
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "port": {
                    "anyOf": [
                      {
                        "type": "number"
                      },
                      {
                        "type": "string",
                        "pattern": "^(?:(?!^-0\\.?0*$)(?:-?(?:(?:0|[1-9]\\d*)(?:\\.\\d+)?)|\\.\\d+?))$"
                      },
                      {
                        "const": ""
                      }
                    ]
                  }
                },
                "required": [
                  "client",
                  "database",
                  "host",
                  "username"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "client": {
                    "const": "sqlite"
                  },
                  "filename": {
                    "type": "string"
                  }
                },
                "required": [
                  "client",
                  "filename"
                ],
                "additionalProperties": false
              }
            ]
          },
          "environment": {
            "enum": [
              "development",
              "local",
              "production",
              "staging",
              "testing"
            ]
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "chartIdIncrementor",
          "charts",
          "details",
          "environment",
          "name"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "theme": {
      "enum": [
        "dark",
        "light",
        "system"
      ],
      "default": "system"
    }
  },
  "additionalProperties": false
}