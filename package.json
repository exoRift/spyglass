{
  "todo": "switch build script to use --production --keep-names when https://github.com/oven-sh/bun/issues/12304 is fixed",
  "name": "spyglass",
  "module": "index.ts",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/exoRift/spyglass",
  "scripts": {
    "dev": "bun run --watch --console-depth=100 src/index.ts",
    "prebuild": "bun run update-schema",
    "build": "NODE_ENV=production vite build src/view && bun build -e vite -e pg -e pg-query-stream -e sqlite3 -e better-sqlite3 -e mysql -e mysql2 -e tedious -e oracledb --compile --compile-autoload-package-json --compile-exec-argv='--console-depth=100 --no-orphans' --define process.env.NODE_ENV='\"production\"' --minify-whitespace --minify-syntax --keep-names --sourcemap src/index.ts --outfile spyglass; rm -rf ./src/view/dist/",
    "lint": "eslint .",
    "update-schema": "bun scripts/updateschema.ts"
  },
  "dependencies": {
    "arktype": "^2.1.20",
    "better-sqlite3": "^12.10.0",
    "echarts": "^6.1.0",
    "knex": "^3.1.0",
    "knex-schema-inspector": "^3.1.0",
    "mysql2": "^3.22.3",
    "open": "^11.0.0",
    "oracledb": "^6.10.0",
    "pg": "^8.21.0",
    "pg-query-stream": "^4.15.0",
    "react-exo-hooks": "^2.3.0",
    "safer-eval": "^1.3.6",
    "tedious": "^19.2.1",
    "webview-bun": "github:exoRift/webview-bun#a51742028afd048ec58bc8eb90fa6870bab7810e"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.2.15",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "custom-types": "github:exoRift/custom-types",
    "daisyui": "^5.5.20",
    "dashup": "^1.1.1",
    "eslint": "^9.28.0",
    "eslint-config": "github:exoRift/eslint-config",
    "eslint-plugin-react-hooks": "^5.2.0",
    "react": "^19.2.6",
    "react-daisyui": "^5.0.5",
    "react-dom": "^19.2.6",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "patchedDependencies": {
    "react-daisyui@5.0.5": "patches/react-daisyui@5.0.5.patch"
  }
}
