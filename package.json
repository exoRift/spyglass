{
  "name": "spyglass",
  "module": "index.ts",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch index.ts",
    "prebuild": "bun run update-schema",
    "build": "NODE_ENV=production vite build view && bun build -e vite -e sqlite3 -e mysql --compile --production --minify --sourcemap index.ts --outfile spyglass; rm -rf ./view/dist/",
    "lint": "eslint .",
    "update-schema": "bun scripts/updateschema.ts"
  },
  "dependencies": {
    "arktype": "^2.1.20",
    "better-sqlite3": "^12.10.0",
    "echarts": "^5.6.0",
    "knex": "^3.1.0",
    "knex-schema-inspector": "^3.1.0",
    "mysql2": "^3.22.3",
    "oracledb": "^6.10.0",
    "pg": "^8.21.0",
    "pg-query-stream": "^4.15.0",
    "react-exo-hooks": "^2.1.2",
    "safer-eval": "^1.3.6",
    "tedious": "^19.2.1",
    "webview-bun": "github:exoRift/webview-bun"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.2.15",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "custom-types": "github:exoRift/custom-types",
    "daisyui": "^5.5.20",
    "dashup": "^1.1.1",
    "eslint": "^9.28.0",
    "eslint-config": "github:exoRift/eslint-config",
    "eslint-plugin-react-hooks": "^5.2.0",
    "react": "^19.2.6",
    "react-daisyui": "^5.0.5",
    "react-dom": "^19.2.6",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-singlefile": "^2.2.0"
  },
  "patchedDependencies": {
    "react-daisyui@5.0.5": "patches/react-daisyui@5.0.5.patch"
  }
}
